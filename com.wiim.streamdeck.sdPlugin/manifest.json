{
  "Author": "Román Martín",
  "UUID": "com.romancin.wiim",
  "CodePath": "plugin.js",
  "Description": "Control your WiiM player directly from Stream Deck",
  "Name": "Wiim Controller",
  "Icon": "imgs/plugin-icon",
  "Version": "1.0.9",
  "SDKVersion": 2,
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "Software": {
    "MinimumVersion": "6.4"
  },
  "OS": [
    { "Platform": "mac", "MinimumVersion": "10.15" },
    { "Platform": "windows", "MinimumVersion": "10" }
  ],
  "Category": "Wiim Controller",
  "CategoryIcon": "imgs/plugin-icon",
  "Actions": [
    {
      "Icon": "imgs/play-icon",
      "Name": "Play / Pause",
      "UUID": "com.romancin.wiim.playpause",
      "Tooltip": "Toggle play and pause on your WiiM",
      "SupportedInMultiActions": true,
      "States": [
        { "Image": "imgs/play-icon", "Name": "Playing" },
        { "Image": "imgs/pause-icon", "Name": "Paused" }
      ],
      "PropertyInspectorPath": "inspector.html"
    },
    {
      "Icon": "imgs/next-icon",
      "Name": "Next Track",
      "UUID": "com.romancin.wiim.next",
      "Tooltip": "Skip to the next track",
      "SupportedInMultiActions": true,
      "States": [{ "Image": "imgs/next-icon" }],
      "PropertyInspectorPath": "inspector.html"
    },
    {
      "Icon": "imgs/prev-icon",
      "Name": "Previous Track",
      "UUID": "com.romancin.wiim.prev",
      "Tooltip": "Go back to the previous track",
      "SupportedInMultiActions": true,
      "States": [{ "Image": "imgs/prev-icon" }],
      "PropertyInspectorPath": "inspector.html"
    },
    {
      "Icon": "imgs/volup-icon",
      "Name": "Volume Up",
      "UUID": "com.romancin.wiim.volup",
      "Tooltip": "Increase volume by 5 points",
      "SupportedInMultiActions": true,
      "States": [{ "Image": "imgs/volup-icon" }],
      "PropertyInspectorPath": "inspector.html"
    },
    {
      "Icon": "imgs/voldown-icon",
      "Name": "Volume Down",
      "UUID": "com.romancin.wiim.voldown",
      "Tooltip": "Decrease volume by 5 points",
      "SupportedInMultiActions": true,
      "States": [{ "Image": "imgs/voldown-icon" }],
      "PropertyInspectorPath": "inspector.html"
    },
    {
      "Icon": "imgs/mute-icon",
      "Name": "Mute",
      "UUID": "com.romancin.wiim.mute",
      "Tooltip": "Mute or unmute the audio",
      "SupportedInMultiActions": true,
      "States": [
        { "Image": "imgs/mute-icon", "Name": "Unmuted" },
        { "Image": "imgs/unmute-icon", "Name": "Muted" }
      ],
      "PropertyInspectorPath": "inspector.html"
    },
    {
      "Icon": "imgs/info-icon",
      "Name": "Now Playing",
      "UUID": "com.romancin.wiim.nowplaying",
      "Tooltip": "Shows the current song on the button",
      "SupportedInMultiActions": false,
      "States": [{ "Image": "imgs/info-icon" }],
      "PropertyInspectorPath": "inspector.html"
    },
    {
      "Icon": "imgs/input-icon",
      "Name": "Input Cycle",
      "UUID": "com.romancin.wiim.inputcycle",
      "Tooltip": "Cycle through configured inputs (WiFi, BT, Line In, Optical, HDMI, USB)",
      "SupportedInMultiActions": true,
      "States": [{ "Image": "imgs/input-icon" }],
      "PropertyInspectorPath": "inspector-input.html"
    },
    {
      "Icon": "imgs/preset-icon",
      "Name": "Preset",
      "UUID": "com.romancin.wiim.preset",
      "Tooltip": "Play a WiiM preset (configured in WiiM Home app)",
      "SupportedInMultiActions": true,
      "States": [{ "Image": "imgs/preset-icon" }],
      "PropertyInspectorPath": "inspector-preset.html"
    },
    {
      "Icon": "imgs/output-icon",
      "Name": "Output Cycle",
      "UUID": "com.romancin.wiim.outputcycle",
      "Tooltip": "Cycle through audio outputs (Optical, Line Out, Coaxial)",
      "SupportedInMultiActions": true,
      "States": [{ "Image": "imgs/output-icon" }],
      "PropertyInspectorPath": "inspector-output.html"
    },
    {
      "Icon": "imgs/dial-icon",
      "Name": "Now Playing Dial",
      "UUID": "com.romancin.wiim.dial",
      "Tooltip": "Stream Deck + dial: album art on screen, rotate for volume or track",
      "Controllers": ["Encoder"],
      "Encoder": {
        "layout": "layouts/wiim-dial-volume.json",
        "StackColor": "#1a1a2e",
        "Icon": "imgs/dial-icon",
        "TriggerDescription": {
          "Rotate": "Volume / Track",
          "Push": "Mute / Play-Pause"
        }
      },
      "States": [{ "Image": "imgs/dial-icon" }],
      "PropertyInspectorPath": "inspector-dial.html"
    }
  ]
}
